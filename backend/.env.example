PORT=3001

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=

# Sonos integration (Phase 13)
# Set to "real" to enable local Sonos control via UPnP
SONOS_MODE=mock

# Optional: comma-separated static IPs if SSDP multicast is blocked on your network
# SONOS_DEVICE_IPS=192.168.1.100,192.168.1.101,192.168.1.102,192.168.1.103

# Optional: room name to use for play/pause/next/previous transport commands (default: Living Room)
# Must match the exact Sonos room name: Living Room, Kitchen, Main Bedroom, Bathroom
# SONOS_PRIMARY_ROOM=Living Room

# Optional: timeouts in milliseconds
# SONOS_DISCOVERY_TIMEOUT=8000
# SONOS_COMMAND_TIMEOUT=5000
